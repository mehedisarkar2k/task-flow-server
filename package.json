{
  "name": "task-flow-server",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "NODE_ENV=production bun build ./src/index.ts --outdir ./dist --target bun --external @better-auth/kysely-adapter --external kysely --external bun:sqlite --minify",
    "run:dev": "bun --watch src/index.ts",
    "create:admin": "bun run scripts/create-admin.ts",
    "seed": "bun run scripts/seed.ts",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1063.0",
    "@aws-sdk/s3-request-presigner": "^3.1063.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "better-auth": "^1.6.14",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.2.0",
    "openai": "^6.42.0",
    "pg": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/pg": "^8.20.0",
    "prisma": "^7.8.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
